generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  accounts     AuthAccount[]
  sessions     Session[]
  guildMembers GuildMember[]
  ownedGuilds  Guild[]   @relation("GuildOwner")
  recordedMvpKills MvpKill[] @relation("RecordedMvpKills")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Guild {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  ownerUserId   String
  owner         User                @relation("GuildOwner", fields: [ownerUserId], references: [id])
  emblemUrl     String              @default("/nightmare-reaper.png")
  description   String              @default("")
  server        String              @default("Ragnarok Online")
  roles         GuildRole[]
  members       GuildMember[]
  invites       GuildInvite[]
  toolAccess    GuildToolAccess[]
  notifications GuildNotification[]
  feedItems     GuildFeedItem[]
  events        GuildEvent[]
  mvpKills      MvpKill[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([ownerUserId])
}

model GuildRole {
  id         String            @id @default(cuid())
  guildId    String
  guild      Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name       String
  color      String            @default("#7dd3fc")
  rank       Int
  members    GuildMember[]
  invites    GuildInvite[]
  events     GuildEvent[]
  toolAccess GuildToolAccess[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([guildId, rank])
  @@index([guildId])
}

model GuildMember {
  id          String        @id @default(cuid())
  guildId     String
  guild       Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  roleId      String
  role        GuildRole     @relation(fields: [roleId], references: [id])
  mainClass   String          @default("")
  status      GuildPresence   @default(offline)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([guildId, userId])
  @@unique([userId])
}

model GuildInvite {
  id        String            @id @default(cuid())
  guildId   String
  guild     Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  email     String
  roleId    String
  role      GuildRole         @relation(fields: [roleId], references: [id])
  status    GuildInviteStatus @default(pending)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([guildId])
  @@index([email])
}

model GuildNotification {
  id        String                @id @default(cuid())
  guildId   String
  guild     Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  title     String
  body      String
  tone      GuildNotificationTone @default(info)
  read      Boolean               @default(false)
  createdAt DateTime              @default(now())

  @@index([guildId, createdAt])
}

model GuildFeedItem {
  id        String            @id @default(cuid())
  guildId   String
  guild     Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  author    String
  title     String
  body      String
  type      GuildFeedItemType @default(activity)
  createdAt DateTime          @default(now())

  @@index([guildId, createdAt])
}

model GuildEvent {
  id           String          @id @default(cuid())
  guildId      String
  guild        Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  title        String
  startsAt     DateTime
  type         GuildEventType  @default(farm)
  requiredRoleId String
  requiredRole GuildRole       @relation(fields: [requiredRoleId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([guildId, startsAt])
}

model GuildToolAccess {
  id            String    @id @default(cuid())
  guildId       String
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  toolId        String
  minimumRoleId String
  minimumRole   GuildRole @relation(fields: [minimumRoleId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([guildId, toolId])
  @@index([guildId])
}

model MvpKill {
  id             String   @id @default(cuid())
  guildId        String
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  mvpName        String
  map            String
  killedAt       DateTime
  respawnMinutes Int
  respawnAt      DateTime
  notes          String?
  recordedById   String
  recordedBy     User     @relation("RecordedMvpKills", fields: [recordedById], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([guildId, respawnAt])
  @@index([recordedById])
}

enum GuildPresence {
  online
  offline
}

enum GuildInviteStatus {
  pending
  accepted
}

enum GuildNotificationTone {
  info
  warning
  success
}

enum GuildFeedItemType {
  announcement
  activity
  system
}

enum GuildEventType {
  woe
  farm
  meeting
}
