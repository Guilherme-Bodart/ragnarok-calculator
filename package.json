{
  "name": "nightmare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm --prefix api run dev",
    "dev:all": "concurrently -n web,api -c cyan,blue \"npm run dev\" \"npm run dev:api\"",
    "sprite:costume": "node scripts/generate-costume-walker.mjs",
    "build": "next build",
    "build:api": "npm --prefix api run build",
    "start": "next start",
    "lint": "eslint",
    "lint:api": "npm --prefix api run lint"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
